    "globals": "^17.5.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.10",
    "yahoo-finance2": "^3.14.0",
    "yaml": "^2.6.1"
