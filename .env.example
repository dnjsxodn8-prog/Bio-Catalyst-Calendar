# Local environment template. Copy to `.env.local` and fill in real values.
# `.env.local`은 .gitignore에 등록되어 commit되지 않음.

# Clerk auth (spec 009 — 가입자 전용 라우트 보호)
# https://dashboard.clerk.com/ → Application → API Keys
# Publishable Key는 클라이언트 번들에 노출되는 게 정상 (비밀 아님). Vercel Project Env 에도 동일하게 추가 필요.
VITE_CLERK_PUBLISHABLE_KEY=

# Clerk Secret Key (spec 019 — 인증 API `/api/private-data` 의 토큰 검증용. 절대 클라이언트 노출 X).
# **Vercel Project Env 에 반드시 추가** — 없으면 인증 앱이 비공개 데이터를 못 받아 에러 상태가 됨.
# 로컬 dev 에서는 vite 미들웨어가 무인증으로 데이터를 공급하므로 불필요.
CLERK_SECRET_KEY=

# (선택, DEV 전용) 로컬에서 로그인 없이 전체 앱(/app)을 점검 — spec 019.
# production 빌드(import.meta.env.DEV=false)에서는 무시되어 절대 활성화되지 않음.
# VITE_AUTH_BYPASS=true

# Telegram bot (export-telegram 스킬용)
# 봇 생성: @BotFather에서 /newbot
# CHAT_ID: 봇과 1:1 또는 채널 추가 후 https://api.telegram.org/bot<TOKEN>/getUpdates 에서 확인
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
