# Local environment template. Copy to `.env.local` and fill in real values.
# `.env.local`은 .gitignore에 등록되어 commit되지 않음.

# Telegram bot (export-telegram 스킬용)
# 봇 생성: @BotFather에서 /newbot
# CHAT_ID: 봇과 1:1 또는 채널 추가 후 https://api.telegram.org/bot<TOKEN>/getUpdates 에서 확인
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
